## 6. `ActionSelector` — Le Contrôleur Symbolique

```javascript
// action-selector.js
class ActionSelector {
  constructor(enemy) {
    this.enemy = enemy;
  }

  /**
   * Tirage roulette wheel parmi les top N candidats.
   * Distribution définie dans le JSON selon le niveau du boss.
   *
   * Niveau 1 : [55%, 30%, 12%, 3%]  → prévisible (ennemi basique)
   * Niveau 2 : [30%, 60%,  7%, 3%]  → sous-optimal (donne l'impression d'apprendre)
   * Niveau 3 : [25%, 45%, 20%, 10%] → équilibré (élite)
   * Niveau 4 : [20%, 40%, 25%, 15%] → imprévisible (boss)
   * Niveau 5 : [15%, 35%, 30%, 20%] → très imprévisible (boss final)
   */
  pick(rankedCandidates) {
    if (rankedCandidates.length === 0) return null;

    const level = String(this.enemy.level);
    const dist  = this.enemy.aiConfig.action_distribution_by_level[level]
               ?? [0.40, 0.35, 0.15, 0.10];

    // Limiter aux candidats disponibles
    const slots      = Math.min(rankedCandidates.length, dist.length);
    const weights    = dist.slice(0, slots);
    const total      = weights.reduce((s, w) => s + w, 0);
    const normalized = weights.map(w => w / total);

    // Tirage
    const roll = Math.random();
    let cumul  = 0;
    for (let i = 0; i < slots; i++) {
      cumul += normalized[i];
      if (roll < cumul) {
        return rankedCandidates[i].action;
      }
    }
    return rankedCandidates[0].action; // fallback
  }
}
```

