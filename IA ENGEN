// enemy-factory.js
class EnemyFactory {
  static async create(enemyId) {
    const data = await fetch(`/data/enemies/${enemyId}.json`).then(r => r.json());

    const klassByArchetype = {
      basic:  EnemyElite,
      elite:  EnemyElite,
      boss:   EnemyBoss,
    };
    const Klass = klassByArchetype[data.archetype] ?? Enemy;
    return new Klass(data, AbilityRegistry);
