## 9. Intégration dans `CombatSystem`

```javascript
// combat-system.js — Tour ennemi
async runEnemyTurn(enemy, gameState) {

  // 1. Tick des statuts (durée -1)
  enemy.tickStatuses();

  // 2. Vérifier transition de phase
  enemy.checkPhaseTransition();

  // 3. Régénération PA
  enemy.stats.pa = Math.min(
    enemy.baseStats.pa,
    enemy.stats.pa + enemy.baseStats.pa_regen_per_turn
  );

  // 4. Décision IA
  const { action, source } = enemy.decideTurn(gameState);

  if (!action) {
    EventBus.emit('combat:log', `${enemy.name} hésite...`);
    return;
  }

  // 5. Annoncer le telegraphe (fenêtre de parade/esquive pour Elior)
  const tele = enemy.telegraph[action.id];
  if (tele) {
    await this.showTelegraph(tele);       // affiche l'indicateur au joueur
    await this.waitForPlayerReaction(tele.duration_ms);
  }

  // 6. Logger l'action
  enemy.logAction(action.id, enemy.aiConfig.memory_buffer_size);
  enemy.stats.pa -= action.pa_cost;

  // 7. Résolution
  await this.executeEnemyAbility(enemy, action, gameState);

  // 8. Mettre à jour la jauge de stabilité (si Elior a réagi)
  if (gameState.playerReactionResult === 'perfect_parry') {
    EventBus.emit('combat:perfect_parry', { enemy });
  }
}
