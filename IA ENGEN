## 5. `EnemyBrain` — Implémentation Détaillée

```javascript
// enemy-brain.js
class EnemyBrain {
  constructor(enemy) {
    this.enemy                = enemy;
    this.playerActionHistory  = [];       // Actions récentes d'Elior + Mira
    this.patternFrequency     = {};       // { 'parry': 0.7, 'sql_injection': 0.4 }
    this.bufferSize           = enemy.aiConfig.memory_buffer_size;
    this.predictionDepth      = enemy.aiConfig.prediction_depth;
    this.patternThreshold     = enemy.aiConfig.pattern_detection_threshold;
  }

  // ── Point d'entrée ─────────────────────────────────
  evaluate(gameState) {
    // 1. Mettre à jour le modèle joueur
    this.updatePlayerModel(gameState.lastPlayerActions);

    // 2. Générer les actions techniquement faisables
    const candidates = this.generateCandidates(gameState);

    // 3. Filtrage dur par contraintes
    const valid = this.applyConstraints(candidates, gameState);

    // 4. Scorer chaque action valide
    const scored = valid.map(action => ({
      action,
      score: this.scoreAction(action, gameState),
    }));

    // 5. Tri décroissant
    return scored.sort((a, b) => b.score - a.score);
  }

  // ── Modèle Joueur — Détection de Patterns ──────────
  updatePlayerModel(recentActions = []) {
    // Intégrer les nouvelles actions dans le buffer
    for (const a of recentActions) {
      this.playerActionHistory.unshift(a);
    }
    // Limiter la taille du buffer
    while (this.playerActionHistory.length > this.bufferSize) {
      this.playerActionHistory.pop();
    }

    // Recalculer les fréquences normalisées
    this.patternFrequency = {};
    for (const a of this.playerActionHistory) {
      this.patternFrequency[a] = (this.patternFrequency[a] ?? 0) + 1;
    }
    const total = this.playerActionHistory.length || 1;
    for (const k in this.patternFrequency) {
      this.patternFrequency[k] /= total;
    }
  }

  // ── Génération des Candidats ────────────────────────
  generateCandidates(gameState) {
    return this.enemy.abilities.filter(ability => {
      // Assez de PA ?
      if (ability.pa_cost > this.enemy.stats.pa) return false;
      // Conditions spécifiques à la capacité
      return this.meetsAbilityConditions(ability, gameState);
    });
  }

  meetsAbilityConditions(ability, gameState) {
    const conds = ability.ai_usage_conditions ?? {};
    if (conds.avoid_when) {
      for (const cond of conds.avoid_when) {
        if (cond === 'already_debuffed_target' && gameState.player.hasStatus('vulnerable_systeme')) {
          return false;
        }
        if (cond === 'already_buffed_stealth' && this.enemy.hasStatus('partial_invisibility')) {
          return false;
        }
      }
    }
    return true;
  }

  // ── Scoring Global ──────────────────────────────────
  scoreAction(action, gameState) {
    let score = 0;

    // A. Score comportemental (agressif / défensif / disruptif)
    score += this.getBehaviorScore(action);

    // B. Contre-stratégie basée sur les patterns d'Elior et Mira
    score += this.getCounterScore(action, gameState);

    // C. Exploitation des points faibles exposés
    score += this.getWeakpointScore(action, gameState);

    // D. Projection Minimax (si niveau suffisant)
    if (this.predictionDepth >= 2) {
      const futureValue = this.minimaxEval(action, gameState, this.predictionDepth);
      score += futureValue * 0.35; // pondération modérée pour ne pas masquer les autres
    }

    // E. Pénalité répétition
    const recentUses = this.enemy.actionHistory
      .slice(0, 3)
      .filter(id => id === action.id).length;
    score *= Math.pow(this.enemy.aiConfig.combo_repeat_penalty, recentUses);

    // F. Mode survie si HP bas
    if (this.enemy.hpPercent < this.enemy.aiConfig.self_preservation_hp_threshold) {
      if (['buff_self', 'heal'].includes(action.category)) score *= 1.70;
      if (action.category === 'attack')                     score *= 0.60;
    }

    // G. Bonus si la cible est en rupture exposée
    if (this.enemy.isBroken) {
      if (action.category === 'attack') score *= 0.10; // ne pas attaquer pendant son propre break
    }

    return Math.max(0, score);
  }

  // A — Comportement selon phase
  getBehaviorScore(action) {
    const weights = this.enemy.currentPhase.behavior_weights;
    const categoryToBehavior = {
      attack:         'aggressive',
      aoe:            'aggressive',
      buff_self:      'defensive',
      heal:           'defensive',
      debuff:         'disruptive',
      counter_setup:  'defensive',
    };
    const behavior = categoryToBehavior[action.category] ?? 'aggressive';
    return (weights[behavior] ?? 0) * 100;
  }

  // B — Contre-stratégie : exploiter les habitudes du joueur
  getCounterScore(action, gameState) {
    let bonus = 0;
    const freq = this.patternFrequency;
    const thr  = this.patternThreshold;

    // Elior pare souvent → favoriser attaques imparables (Buffer Overflow casse la garde)
    if ((freq['parry'] ?? 0) > thr) {
      if (action.breaks_guard) bonus += 40;
    }

    // Elior spam Kernel Patch → anticipation défensive de Rootkit
    if ((freq['kernel_patch'] ?? 0) > thr) {
      if (action.id === 'purge_buff') bonus += 35;
      if (action.id === 'stealth_cloak') bonus += 25;
    }

    // Mira utilise souvent Deep Scan → purger les marques
    if ((freq['deep_scan'] ?? 0) > thr) {
      if (action.id === 'purge_buff') bonus += 30;
    }

    // Elior charge une grosse compétence → interrompre
    if (gameState.playerIsCharging) {
      if (action.interruptive) bonus += 55;
    }

    // Elior a les HP bas → finir
    if (gameState.playerHPPercent < 0.30) {
      if (action.category === 'attack') bonus += 45;
    }

    // BYTE vient de booster un allié → dissiper
    if (gameState.byteJustBuffed) {
      if (action.effects?.some(e => e.type === 'dispel')) bonus += 30;
    }

    return bonus;
  }

  // C — Exploitation des points faibles
  getWeakpointScore(action, gameState) {
    const exposed = this.enemy.weakpoints.filter(w => w.isExposed);
    for (const wp of exposed) {
      if (action.category === 'attack') {
        // L'ennemi ne s'auto-attaque pas → bonus pour guider la lecture
        // (utile pour que l'ennemi attaque le bon personnage vulnérable)
        return 0; // les weakpoints comptent pour le joueur, pas l'ennemi sur lui-même
      }
    }
    // Score pour les actions qui exposent de nouveaux weakpoints (manipulation d'état)
    if (action.id === 'systemic_aoe' && !gameState.player.hasStatus('vulnerable_systeme')) {
      return 20; // rend le joueur plus vulnérable ensuite
    }
    return 0;
  }

  // D — Minimax tronqué (profondeur 2)
  minimaxEval(action, gameState, depth) {
    if (depth === 0) return this.heuristicEval(gameState);

    // Simuler l'effet de l'action sur l'état
    const simState = this.simulateEnemyAction(action, gameState);

    // Prédire la meilleure réponse d'Elior (ou de Mira)
    const playerResponse   = this.predictBestPlayerResponse(simState);
    const afterPlayerState = this.simulatePlayerAction(playerResponse, simState);

    // Récursion (depth - 1)
    return this.heuristicEval(afterPlayerState);
  }

  // Heuristique d'évaluation de position
  heuristicEval(state) {
    // Différence de HP normalisée + avantage de statuts
    const enemyHP    =  state.enemy.hpPercent * 70;
    const playerHP   = -state.player.hpPercent * 70;
    const statusAdv  =  state.enemy.statusEffects.length * 5
                      - state.player.statusEffects.length * 8;
    const breakBonus =  state.enemy.isBroken ? -30 : 0; // le break pénalise l'ennemi
    return enemyHP + playerHP + statusAdv + breakBonus;
  }

  predictBestPlayerResponse(state) {
    // Modèle simplifié : le joueur utilise son action la plus fréquente,
    // pondérée par la situation (HP bas → attaque lourde)
    if (state.player.hpPercent < 0.30) return 'zero_day'; // desperado
    if (state.player.hpPercent > 0.70) return 'kernel_patch'; // optimal quand safe

    const sorted = Object.entries(this.patternFrequency)
      .sort((a, b) => b[1] - a[1]);
    return sorted[0]?.[0] ?? 'ping_sweep';
  }

  simulateEnemyAction(action, gameState) {
    const playerDmg = action.category === 'attack'
      ? Math.round(this.enemy.stats.atq * 0.8)
      : 0;
    return {
      ...gameState,
      player: {
        ...gameState.player,
        hp: Math.max(0, gameState.player.hp - playerDmg),
        hpPercent: Math.max(0, gameState.player.hpPercent - playerDmg / gameState.player.hp_max),
      },
    };
  }

  simulatePlayerAction(actionId, gameState) {
    const dmgTable = {
      zero_day:       220,
      buffer_overflow: 180,
      sql_injection:   150,
      kernel_patch:     80,
      ping_sweep:       45,
    };
    const dmg = dmgTable[actionId] ?? 60;
    return {
      ...gameState,
      enemy: {
        ...gameState.enemy,
        hp:       Math.max(0, gameState.enemy.hp - dmg),
        hpPercent: Math.max(0, gameState.enemy.hpPercent - dmg / gameState.enemy.hp_max),
      },
    };
  }

  // ── Contraintes (filtrage dur) ───────────────────────
  applyConstraints(candidates, gameState) {
    return candidates.filter(action =>
      this.enemy.constraints.every(c => this.constraintPasses(c, action, gameState))
    );
  }

  constraintPasses(constraint, action, gameState) {
    switch (constraint.rule) {

      case 'no_repeat_same_skill': {
        const recent = this.enemy.actionHistory.slice(0, constraint.turns);
        return !recent.includes(action.id);
      }

      case 'reserve_pa_for_reaction': {
        if (!gameState.playerIsCharging) return true;
        const remaining = this.enemy.stats.pa - action.pa_cost;
        return remaining >= constraint.pa_min;
      }

      case 'go_defensive_if_hp_below': {
        if (this.enemy.hpPercent > constraint.hp_percent) return true;
        return ['buff_self', 'heal', 'defensive'].includes(action.category);
      }

      case 'use_aoe_if_multiple_alive': {
        if (action.category !== 'aoe') return true;
        return (gameState.aliveAllies ?? 0) >= constraint.min_allies;
      }

      case 'prioritize_break_if_close': {
        // Pas un filtre dur — géré dans le scoring via getBehaviorScore
        return true;
      }

      default:
        return true;
    }
  }
}
