## 3. Modélisation OOP

### 3.1 Hiérarchie des Classes

```
Entity                    ← classe abstraite de base
├── Enemy
│   ├── EnemyElite        ← Firewall basique, Malware Trojan
│   └── EnemyBoss
│       └── BossMultiphase ← Rootkit Alpha, boss finaux
├── PlayerCharacter       ← Elior
├── AllyNPC               ← Mira
└── Companion             ← BYTE (robot)
```

### 3.2 Classe `Entity` — Base Abstraite

```javascript
// entity.js
class Entity {
  constructor(data) {
    this.id             = data.id;
    this.name           = data.name;
    this.baseStats      = structuredClone(data.stats);
    this.stats          = structuredClone(data.stats);
    this.statusEffects  = [];
    this.actionHistory  = [];   // Buffer circulaire des actions passées
  }

  get isAlive()    { return this.stats.hp > 0; }
  get hpPercent()  { return this.stats.hp / this.stats.hp_max; }

  applyDamage(amount) {
    this.stats.hp = Math.max(0, this.stats.hp - amount);
  }

  applyStatus(status) {
    // Pas de doublon — rafraîchit la durée si déjà présent
    const existing = this.statusEffects.find(s => s.id === status.id);
    if (existing) existing.duration = Math.max(existing.duration, status.duration);
    else this.statusEffects.push({ ...status });
  }

  hasStatus(id) {
    return this.statusEffects.some(s => s.id === id);
  }

  tickStatuses() {
    this.statusEffects = this.statusEffects
      .map(s => ({ ...s, duration: s.duration - 1 }))
      .filter(s => s.duration > 0);
  }

  // Buffer circulaire — garde les N dernières actions
  logAction(actionId, bufferSize = 10) {
    this.actionHistory.unshift(actionId);
    if (this.actionHistory.length > bufferSize) {
      this.actionHistory.pop();
    }
  }
}
```

### 3.3 Classe `Enemy`

```javascript
// enemy.js
class Enemy extends Entity {
  constructor(data, abilityRegistry) {
    super(data);

    this.level          = data.level;
    this.archetype      = data.archetype;
    this.typeTags       = data.type_tags;
    this.resistances    = { ...data.resistances };
    this.weakpoints     = data.weakpoints.map(w => ({ ...w, isExposed: false }));
    this.stabilityDmgTable = data.stability_damage_table;
    this.phases         = data.phases;
    this.currentPhase   = data.phases[0];
    this.aiConfig       = data.ai_config;
    this.constraints    = data.constraints;
    this.reactions      = data.reactions;
    this.telegraph      = data.telegraph;
    this.isBroken       = false;

    // Résolution des capacités depuis le registre global
    this.abilities = this.resolveAbilities(this.currentPhase.ability_pool, abilityRegistry);

    // Composants IA — découplés, injectables
    this.brain    = new EnemyBrain(this);
    this.selector = new ActionSelector(this);
  }

  // ── Résistances & Dégâts ─────────────────────────────
  computeDamageReceived(rawDamage, atkType, targetWeakpointId = null) {
    const resist = this.resistances[atkType] ?? 1.0;

    let wpMult = 1.0;
    if (targetWeakpointId) {
      const wp = this.weakpoints.find(w => w.id === targetWeakpointId && w.isExposed);
      if (wp) wpMult = wp.damage_multiplier;
    }

    // Statut "vulnerable_systeme" → -25% DEF
    const defMult = this.hasStatus('vulnerable_systeme') ? 0.75 : 1.0;

    return Math.round(rawDamage * resist * wpMult * defMult);
  }

  // ── Jauge de Stabilité (Break) ───────────────────────
  applyStabilityDamage(abilityId) {
    const base  = this.stabilityDmgTable[abilityId] ?? 0;
    const bonus = this.weakpoints
      .filter(w => w.isExposed && w.triggered_by.includes(abilityId))
      .reduce((sum, w) => sum + (w.stability_drain_bonus ?? 0), 0);

    this.stats.stability = Math.max(0, this.stats.stability - base - bonus);

    if (this.stats.stability === 0 && !this.isBroken) this.triggerBreak();
  }

  triggerBreak() {
    this.isBroken    = true;
    this.stats.def   = Math.round(this.stats.def * 0.50);
    this.stats.vit   = Math.round(this.stats.vit * 0.70);
    EventBus.emit('enemy:break', { enemy: this });

    // Fin du break après 1 tour
    setTimeout(() => {
      this.isBroken      = false;
      this.stats.def     = this.baseStats.def;
      this.stats.vit     = this.baseStats.vit;
      this.stats.stability = this.baseStats.stability_max;
    }, 3500);
  }

  // ── Transitions de Phase ─────────────────────────────
  checkPhaseTransition() {
    for (const phase of this.phases) {
      if (
        this.hpPercent * 100 <= phase.trigger_hp_percent &&
        phase.id !== this.currentPhase.id
      ) {
        this.enterPhase(phase);
        break;
      }
    }
  }

  enterPhase(phase) {
    this.currentPhase = phase;
    this.abilities    = this.resolveAbilities(phase.ability_pool, AbilityRegistry);

    if (phase.stat_modifiers.vit_bonus) this.stats.vit += phase.stat_modifiers.vit_bonus;
    if (phase.stat_modifiers.atq_bonus) this.stats.atq += phase.stat_modifiers.atq_bonus;
    if (phase.status_on_enter) {
      phase.status_on_enter.forEach(s => this.applyStatus({ id: s, duration: 999 }));
    }

    EventBus.emit('enemy:phase_change', { enemy: this, phase });
  }

  // ── Tour Ennemi ─────────────────────────────────────
  decideTurn(gameState) {
    // 1. Réactions prioritaires définies dans le JSON
    const reaction = this.checkReactions(gameState);
    if (reaction) return { action: reaction, source: 'reaction' };

    // 2. Évaluation IA → ActionSelector
    const candidates = this.brain.evaluate(gameState);
    const chosen     = this.selector.pick(candidates);
    return { action: chosen, source: 'brain' };
  }

  checkReactions(gameState) {
    if (gameState.playerJustPerfectParried && this.reactions.on_perfect_parry_received) {
      return this.abilities.find(a => a.id === this.reactions.on_perfect_parry_received);
    }
    if (this.isBroken && this.reactions.on_break) {
      return null; // null_action = ne fait rien pendant le break
    }
    if (gameState.playerHPPercent < 0.25 && this.reactions.on_player_low_hp) {
      return this.abilities.find(a => a.id === this.reactions.on_player_low_hp);
    }
    if (gameState.miraJustScanned && this.reactions.on_mira_scan) {
      return this.abilities.find(a => a.id === this.reactions.on_mira_scan);
    }
    return null;
  }

  resolveAbilities(pool, registry) {
    return pool.map(id => registry.get(id)).filter(Boolean);
  }
}
```

